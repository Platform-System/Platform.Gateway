{
  "ReverseProxy": {
    "Routes": {
      "catalog-api-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/catalog/{**catch-all}",
          "Methods": [ "GET", "POST", "PUT", "DELETE" ]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/catalog" },
          { "PathPrefix": "/api" }
        ]
      },
      "catalog-swagger-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/swagger/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathRemovePrefix": "/catalog" }
        ]
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog-destination": {
            "Address": "http://localhost:5002/"
          }
        }
      }
    }
  }
}
